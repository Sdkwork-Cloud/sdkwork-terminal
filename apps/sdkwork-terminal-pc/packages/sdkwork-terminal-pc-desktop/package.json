{
  "name": "@sdkwork/terminal-pc-desktop",
  "version": "0.2.59",
  "private": true,
  "description": "SDKWork Terminal PC Desktop native host package for Tauri.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./host": {
      "types": "./src/host/index.ts",
      "import": "./src/host/index.ts",
      "default": "./src/host/index.ts"
    }
  },
  "scripts": {
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:prod": "tauri build --config tauri.release.conf.json",
    "typecheck": "node ../../node_modules/.pnpm/typescript@*/node_modules/typescript/bin/tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "typescript": "^5.8.2",
    "@types/node": "^20.0.0"
  }
}




