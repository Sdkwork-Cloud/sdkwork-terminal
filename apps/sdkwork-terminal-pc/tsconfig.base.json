{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@sdkwork/terminal-pc-shell": ["packages/sdkwork-terminal-pc-shell/src/index.tsx"],
      "@sdkwork/terminal-pc-shell/integration": ["packages/sdkwork-terminal-pc-shell/src/integration.tsx"],
      "@sdkwork/terminal-pc-workbench": ["packages/sdkwork-terminal-pc-workbench/src/index.tsx"],
      "@sdkwork/terminal-pc-sessions": ["packages/sdkwork-terminal-pc-sessions/src/index.tsx"],
      "@sdkwork/terminal-pc-sessions/*": ["packages/sdkwork-terminal-pc-sessions/src/*"],
      "@sdkwork/terminal-pc-resources": ["packages/sdkwork-terminal-pc-resources/src/index.tsx"],
      "@sdkwork/terminal-pc-resources/*": ["packages/sdkwork-terminal-pc-resources/src/*"],
      "@sdkwork/terminal-pc-ai-cli": ["packages/sdkwork-terminal-pc-ai-cli/src/index.tsx"],
      "@sdkwork/terminal-pc-settings": ["packages/sdkwork-terminal-pc-settings/src/index.tsx"],
      "@sdkwork/terminal-pc-diagnostics": ["packages/sdkwork-terminal-pc-diagnostics/src/index.tsx"],
      "@sdkwork/terminal-pc-core": ["packages/sdkwork-terminal-pc-core/src/index.ts"],
      "@sdkwork/terminal-pc-infrastructure": ["packages/sdkwork-terminal-pc-infrastructure/src/index.ts"],
      "@sdkwork/terminal-pc-contracts": ["packages/sdkwork-terminal-pc-contracts/src/index.ts"],
      "@sdkwork/terminal-pc-types": ["packages/sdkwork-terminal-pc-types/src/index.ts"],
      "@sdkwork/terminal-pc-ui": ["packages/sdkwork-terminal-pc-ui/src/index.tsx"],
      "@sdkwork/terminal-pc-i18n": ["packages/sdkwork-terminal-pc-i18n/src/index.ts"],
      "@sdkwork/terminal-pc-commons": ["packages/sdkwork-terminal-pc-commons/src/index.ts"]
    }
  }
}
