{
  "name": "@sdkwork/terminal-workspace",
  "private": true,
  "version": "0.2.59",
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "node ../../scripts/terminal-dev.mjs --target desktop",
    "dev:web": "node ../../scripts/terminal-dev.mjs --target web",
    "lint": "node tools/scripts/run-quality-check.mjs",
    "test": "node tools/scripts/run-workspace-tests.mjs",
    "test:runtime-event-name-contract": "node --experimental-strip-types tests/runtime-event-name-contract.test.ts",
    "build": "node tools/scripts/run-web-vite.mjs build && node tools/scripts/run-vite-host.mjs build",
    "build:web": "node tools/scripts/run-web-vite.mjs build",
    "build:desktop": "node tools/scripts/run-vite-host.mjs build",
    "typecheck": "node tools/scripts/run-typescript-cli.mjs --project tsconfig.web.json --noEmit && node tools/scripts/run-typescript-cli.mjs --project tsconfig.desktop.json --noEmit",
    "tauri:check": "cargo check --manifest-path packages/sdkwork-terminal-pc-desktop/src-tauri/Cargo.toml",
    "runtime-node:dev": "cargo run --manifest-path crates/sdkwork-terminal-runtime-node/Cargo.toml --bin sdkwork-terminal-runtime-node",
    "tauri:dev": "node ../../scripts/terminal-dev.mjs --target desktop",
    "tauri:build": "node tools/scripts/run-tauri-cli.mjs build --config packages/sdkwork-terminal-pc-desktop/src-tauri/tauri.release.conf.json",
    "smoke:windows-release-launch": "node tools/smoke/windows-release-launch-probe.mjs --inspect-launch --assert-passed --startup-delay-ms 6000",
    "verify": "node tools/scripts/run-full-verification.mjs",
    "verify:terminal-runtime": "node tools/scripts/verify-terminal-runtime.mjs",
    "verify:shell-package": "node --experimental-test-isolation=none --test tests/shell-third-party-consumer-smoke.test.mjs",
    "verify:typescript-probes": "node tools/scripts/run-typescript-probe-tests.mjs",
    "verify:windows-release": "node tools/scripts/verify-windows-release.mjs"
  },
  "dependencies": {
    "@sdkwork/appbase-app-sdk": "workspace:*",
    "@sdkwork/auth-runtime-pc-react": "workspace:*",
    "@sdkwork/iam-contracts": "workspace:*",
    "@sdkwork/sdk-common": "^1.0.2",
    "@tauri-apps/api": "^2.0.0",
    "lucide-react": "^0.546.0",
    "qrcode": "^1.5.4",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@sdkwork/utils": "workspace:*",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.0",
    "typescript": "^5.8.2",
    "@sdkwork/terminal-pc-contracts": "workspace:*",
    "@sdkwork/terminal-pc-types": "workspace:*"
  }
}
