# Terminal topology profile: self-hosted + split-services + development

SDKWORK_TERMINAL_HOSTING=self-hosted
SDKWORK_TERMINAL_SERVICE_LAYOUT=split-services
SDKWORK_TERMINAL_ENVIRONMENT=development
SDKWORK_TERMINAL_PROFILE_ID=self-hosted.split-services.development

SDKWORK_TERMINAL_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:9620
SDKWORK_TERMINAL_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:9620
SDKWORK_RUNTIME_NODE_BIND_ADDR=127.0.0.1:9620
SDKWORK_ACCESS_TOKEN=

SDKWORK_API_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_API_GATEWAY_CONFIG=../sdkwork-api-gateway/configs/sdkwork-api-gateway.development.toml.example
SDKWORK_TERMINAL_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
SDKWORK_TERMINAL_PLATFORM_API_GATEWAY_AUTOSTART=true

SDKWORK_TERMINAL_CLIENT_DESKTOP_RENDERER_BIND=127.0.0.1:1420
SDKWORK_TERMINAL_CLIENT_DESKTOP_RENDERER_HTTP_URL=http://127.0.0.1:1420
SDKWORK_TERMINAL_CLIENT_WEB_RENDERER_BIND=127.0.0.1:4173
SDKWORK_TERMINAL_CLIENT_WEB_RENDERER_HTTP_URL=http://127.0.0.1:4173

VITE_SDKWORK_TERMINAL_HOSTING=self-hosted
VITE_SDKWORK_TERMINAL_ENVIRONMENT=development
VITE_SDKWORK_TERMINAL_IAM_REQUIRED=false
VITE_SDKWORK_TERMINAL_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:9620
VITE_SDKWORK_TERMINAL_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
VITE_SDKWORK_TERMINAL_RUNTIME_WORKSPACE_ID=workspace-runtime
VITE_SDKWORK_TERMINAL_RUNTIME_AUTHORITY=runtime://edge-node-a
VITE_SDKWORK_TERMINAL_RUNTIME_TARGET=remote-runtime
VITE_SDKWORK_TERMINAL_CLIENT_DESKTOP_RENDERER_HTTP_URL=http://127.0.0.1:1420
VITE_SDKWORK_TERMINAL_CLIENT_WEB_RENDERER_HTTP_URL=http://127.0.0.1:4173
