# Terminal topology profile: self-hosted + split-services + production

SDKWORK_TERMINAL_HOSTING=self-hosted
SDKWORK_TERMINAL_SERVICE_LAYOUT=split-services
SDKWORK_TERMINAL_ENVIRONMENT=production
SDKWORK_TERMINAL_PROFILE_ID=self-hosted.split-services.production

SDKWORK_TERMINAL_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:9620
SDKWORK_TERMINAL_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:9620
SDKWORK_RUNTIME_NODE_BIND_ADDR=127.0.0.1:9620

SDKWORK_API_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_TERMINAL_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
SDKWORK_TERMINAL_PLATFORM_API_GATEWAY_AUTOSTART=false

VITE_SDKWORK_TERMINAL_HOSTING=self-hosted
VITE_SDKWORK_TERMINAL_ENVIRONMENT=production
VITE_SDKWORK_TERMINAL_IAM_REQUIRED=true
VITE_SDKWORK_TERMINAL_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:9620
VITE_SDKWORK_TERMINAL_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
