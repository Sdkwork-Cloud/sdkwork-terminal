# Terminal topology profile: cloud-hosted + split-services + production

SDKWORK_TERMINAL_HOSTING=cloud-hosted
SDKWORK_TERMINAL_SERVICE_LAYOUT=split-services
SDKWORK_TERMINAL_ENVIRONMENT=production
SDKWORK_TERMINAL_PROFILE_ID=cloud-hosted.split-services.production

SDKWORK_TERMINAL_APPLICATION_PUBLIC_HTTP_URL=https://api.sdkwork.com/apps/sdkwork-terminal
SDKWORK_TERMINAL_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
SDKWORK_TERMINAL_PLATFORM_API_GATEWAY_AUTOSTART=false

VITE_SDKWORK_TERMINAL_HOSTING=cloud-hosted
VITE_SDKWORK_TERMINAL_ENVIRONMENT=production
VITE_SDKWORK_TERMINAL_IAM_REQUIRED=true
VITE_SDKWORK_TERMINAL_APPLICATION_PUBLIC_HTTP_URL=https://api.sdkwork.com/apps/sdkwork-terminal
VITE_SDKWORK_TERMINAL_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com

SDKWORK_RUNTIME_NODE_REQUIRE_AUTH=true
