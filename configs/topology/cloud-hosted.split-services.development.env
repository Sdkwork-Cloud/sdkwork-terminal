# Terminal topology profile: cloud-hosted + split-services + development

SDKWORK_TERMINAL_HOSTING=cloud-hosted
SDKWORK_TERMINAL_SERVICE_LAYOUT=split-services
SDKWORK_TERMINAL_ENVIRONMENT=development
SDKWORK_TERMINAL_PROFILE_ID=cloud-hosted.split-services.development

SDKWORK_TERMINAL_APPLICATION_PUBLIC_HTTP_URL=https://api-dev.sdkwork.com/apps/sdkwork-terminal
SDKWORK_TERMINAL_PLATFORM_API_GATEWAY_HTTP_URL=https://api-dev.sdkwork.com
SDKWORK_TERMINAL_PLATFORM_API_GATEWAY_AUTOSTART=false

SDKWORK_TERMINAL_CLIENT_DESKTOP_RENDERER_BIND=127.0.0.1:1420
SDKWORK_TERMINAL_CLIENT_DESKTOP_RENDERER_HTTP_URL=http://127.0.0.1:1420
SDKWORK_TERMINAL_CLIENT_WEB_RENDERER_BIND=0.0.0.0:4173
SDKWORK_TERMINAL_CLIENT_WEB_RENDERER_HTTP_URL=http://127.0.0.1:4173

VITE_SDKWORK_TERMINAL_HOSTING=cloud-hosted
VITE_SDKWORK_TERMINAL_ENVIRONMENT=development
VITE_SDKWORK_TERMINAL_IAM_REQUIRED=true
VITE_SDKWORK_TERMINAL_APPLICATION_PUBLIC_HTTP_URL=https://api-dev.sdkwork.com/apps/sdkwork-terminal
VITE_SDKWORK_TERMINAL_PLATFORM_API_GATEWAY_HTTP_URL=https://api-dev.sdkwork.com
VITE_SDKWORK_TERMINAL_CLIENT_DESKTOP_RENDERER_HTTP_URL=http://127.0.0.1:1420
VITE_SDKWORK_TERMINAL_CLIENT_WEB_RENDERER_HTTP_URL=http://127.0.0.1:4173
