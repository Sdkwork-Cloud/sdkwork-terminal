{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for sdkwork-terminal desktop host",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "desktop-host-commands",
    "core:window:allow-center",
    "core:window:allow-close",
    "core:window:allow-hide",
    "core:window:allow-inner-size",
    "core:window:allow-is-focused",
    "core:window:allow-is-maximized",
    "core:window:allow-is-minimized",
    "core:window:allow-maximize",
    "core:window:allow-minimize",
    "core:window:allow-outer-size",
    "core:window:allow-request-user-attention",
    "core:window:allow-scale-factor",
    "core:window:allow-set-focus",
    "core:window:allow-set-max-size",
    "core:window:allow-set-min-size",
    "core:window:allow-set-position",
    "core:window:allow-set-resizable",
    "core:window:allow-set-size",
    "core:window:allow-set-title",
    "core:window:allow-show",
    "core:window:allow-start-dragging",
    "core:window:allow-start-resize-dragging",
    "core:window:allow-toggle-maximize",
    "core:window:allow-unmaximize",
    "core:webview:default",
    "allow-desktop-host-status",
    "allow-desktop-daemon-health",
    "allow-desktop-daemon-start",
    "allow-desktop-daemon-stop",
    "allow-desktop-daemon-reconnect",
    "allow-desktop-session-index",
    "allow-desktop-session-replay-slice",
    "allow-desktop-session-attach",
    "allow-desktop-session-detach",
    "allow-desktop-session-reattach",
    "allow-desktop-connector-launch",
    "allow-desktop-connector-session-create",
    "allow-desktop-connector-exec-probe",
    "allow-desktop-execution-target-catalog",
    "allow-desktop-local-shell-exec",
    "allow-desktop-local-shell-session-create",
    "allow-desktop-session-input",
    "allow-desktop-session-input-bytes",
    "allow-desktop-local-shell-session-input",
    "allow-desktop-local-shell-session-input-bytes",
    "allow-desktop-session-attachment-acknowledge",
    "allow-desktop-session-resize",
    "allow-desktop-session-terminate",
    "allow-desktop-local-shell-session-resize",
    "allow-desktop-local-shell-session-terminate"
  ]
}
